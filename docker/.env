# =============================================================================
# UMI Docker 环境变量配置
# =============================================================================
# 这个文件被 docker-compose.yml 自动读取（docker compose 的默认行为）。
# 修改变量值后无需重新构建镜像，下次 docker compose up/run 时自动生效。
#
# 格式：变量名=值
# 注意：等号两边不要有空格！

# ---- 用户身份 ----
# 容器内用户的 UID 和 GID，应该与宿主机用户一致。
# 运行 id -u 和 id -g 可以查看你的 UID/GID。
# 如果不确定，保持默认值 1000 即可（Ubuntu 第一个用户的默认值）。
USER_UID=1000
USER_GID=1000
USER_NAME=dev

# ---- 显示 ----
# X11 Server 的显示编号。
# 大多数单显示器系统是 :0，多显示器或多 seat 可能是 :1。
# 运行 echo $DISPLAY 可以查看当前值。
DISPLAY=:0

# ---- ROS2 通信域 ----
# ROS_DOMAIN_ID 用于隔离不同组的 ROS2 节点。
# 同一 domain 内的节点可以互相发现和通信。
# 0 是默认值。如果你的局域网内有其他 ROS2 设备，建议设置为一个独特的数字（0-232）。
ROS_DOMAIN_ID=0
