# =============================================================================
# UMI 项目 Makefile —— 常用命令的快捷入口
# =============================================================================
# 所有 docker compose 命令都应该从 docker/ 目录下运行，
# 因为 docker-compose.yml 和 .env 都在那里，且 build context 是项目根目录。
#
# 为什么要写 Makefile？
#   - 命令太长（docker compose -f docker/docker-compose.yml ...），不好记
#   - 统一入口，新人看到 Makefile 就知道有哪些操作
#   - .PHONY 声明告诉 make 这些不是文件名，不会与同名文件冲突

# docker compose 命令的前缀
# --project-directory docker : 指定 compose 文件所在目录
COMPOSE = docker compose --project-directory docker

.PHONY: help build shell up down exec clean logs

# ---------------------------------------------------------------------------
# 默认目标：显示帮助
# ---------------------------------------------------------------------------
help:
	@echo "UMI Docker 开发环境"
	@echo ""
	@echo "  make build   构建 Docker 镜像"
	@echo "  make shell   进入容器交互式 shell"
	@echo "  make up      后台启动容器"
	@echo "  make down    停止并删除容器"
	@echo "  make exec    在运行中的容器内执行命令"
	@echo "  make logs    查看容器日志"
	@echo "  make clean   清理 Docker 构建缓存"

# ---------------------------------------------------------------------------
# 构建镜像
# ---------------------------------------------------------------------------
# --no-cache : 不使用缓存，从头构建（首次或调试时推荐）
# 如果只是添加 Python 包等增量修改，可以去掉 --no-cache 加速构建
build:
	$(COMPOSE) build --no-cache

# ---------------------------------------------------------------------------
# 快速重新构建（利用缓存）
# ---------------------------------------------------------------------------
rebuild:
	$(COMPOSE) build

# ---------------------------------------------------------------------------
# 进入容器（最常用的命令）
# ---------------------------------------------------------------------------
# -rm : 退出容器后自动删除容器实例（不是删除镜像），保持系统干净
# 使用方式：
#   make shell              → 进入 bash
#   make shell cmd="pytest" → 进入容器执行 pytest 然后退出
shell:
	$(COMPOSE) run --rm umi-dev $(cmd)

# ---------------------------------------------------------------------------
# 后台运行容器
# ---------------------------------------------------------------------------
# -d : detached 模式，容器在后台运行
# 适合需要长时间运行服务的场景（如 ros2 launch 启动了多个节点）
up:
	$(COMPOSE) up -d

# ---------------------------------------------------------------------------
# 停止容器
# ---------------------------------------------------------------------------
down:
	$(COMPOSE) down

# ---------------------------------------------------------------------------
# 在已运行的容器内执行命令
# ---------------------------------------------------------------------------
# 与 shell 的区别：
#   - shell 是 docker compose run（启动新容器，用完即删）
#   - exec 是 docker compose exec（连接到已经在运行的容器）
# 使用方式：make exec cmd="ros2 topic list"
exec:
	$(COMPOSE) exec umi-dev $(cmd)

# ---------------------------------------------------------------------------
# 查看日志
# ---------------------------------------------------------------------------
# -f : follow 模式，持续输出新日志（Ctrl+C 退出）
logs:
	$(COMPOSE) logs -f

# ---------------------------------------------------------------------------
# 清理
# ---------------------------------------------------------------------------
# 删除构建缓存和悬空镜像（释放磁盘空间）
# 不影响已构建好的 umi-dev 镜像
clean:
	$(COMPOSE) down --rmi all --volumes 2>/dev/null || true
	docker builder prune -f
	@echo "清理完成"
