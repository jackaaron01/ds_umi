# =============================================================================
# .dockerignore —— 排除不需要发送到 Docker 构建上下文的文件
# =============================================================================
# Docker 构建时，首先将构建上下文（整个 umi/ 目录）打包发送给 Docker daemon。
# 如果有大文件或敏感文件在里面，会导致构建缓慢或安全问题。
# .dockerignore 告诉 Docker "这些文件不要打包"。
#
# 规则：排除一切不需要在镜像构建时使用的东西。源码通过 volume 挂载运行时使用。

# ---- Python 缓存和虚拟环境 ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
*.whl
.venv/
venv/

# ---- 编译产物（如果有的话） ----
build/
install/
log/

# ---- Git ----
.git/
.gitignore

# ---- IDE 和编辑器 ----
.vscode/
.idea/
*.swp
*.swo

# ---- 操作系统杂项 ----
.DS_Store
Thumbs.db

# ---- 敏感文件 ----
.env.local
*.pem
*.key
credentials/

# ---- 数据文件（体积大，且不需要在构建时用） ----
*.bag
*.h5
*.hdf5
data/
recordings/
