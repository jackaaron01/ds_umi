<mujoco model="xarm6_gripper">
  <compiler angle="radian" meshdir="meshes"/>

  <asset>
    <mesh name="link_base" file="link_base.obj"/>
    <mesh name="link1" file="link1.obj"/>
    <mesh name="link2" file="link2.obj"/>
    <mesh name="link3" file="link3.obj"/>
    <mesh name="link4" file="link4.obj"/>
    <mesh name="link5" file="link5.obj"/>
    <mesh name="link6" file="link6.obj"/>
    <mesh name="base_link_stl" file="base_link.stl"/>
    <mesh name="left_outer_knuckle" file="left_outer_knuckle.stl"/>
    <mesh name="left_finger" file="left_finger.stl"/>
    <mesh name="left_inner_knuckle" file="left_inner_knuckle.stl"/>
    <mesh name="right_outer_knuckle" file="right_outer_knuckle.stl"/>
    <mesh name="right_finger" file="right_finger.stl"/>
    <mesh name="right_inner_knuckle" file="right_inner_knuckle.stl"/>
  </asset>

  <default>
    <joint limited="true" damping="10"/>
    <position ctrllimited="true" forcerange="-50 50" kp="100"/>
  </default>

  <worldbody>
    <camera name="fixed" pos="1.2 0 1.0" xyaxes="-1 0 0 0 -0.5 1"/>
    <!-- Mocap markers for goal-conditioned tasks -->
    <body name="marker_red" mocap="true" pos="0.3 0.2 0.5">
      <geom type="sphere" size="0.04" rgba="1 0.2 0.2 1" contype="0" conaffinity="0"/>
    </body>
    <body name="marker_green" mocap="true" pos="0.1 -0.2 0.4">
      <geom type="sphere" size="0.04" rgba="0.2 1 0.2 1" contype="0" conaffinity="0"/>
    </body>

    <!-- Base link -->
    <geom type="mesh" rgba="0.35 0.35 0.4 1" mesh="link_base"/>

    <!-- Link1 (joint1: base rotation) -->
    <body name="link1" pos="0 0 0.267">
      <inertial pos="-0.00017 0.03575 -0.00647" quat="0.510265 0.859977 -0.00829593 -0.000248212" mass="2.531" diaginertia="0.00564532 0.00489292 0.00347376"/>
      <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-6.28319 6.28319"/>
      <geom type="mesh" rgba="0.35 0.35 0.4 1" mesh="link1"/>

      <!-- Link2 (joint2: shoulder lift) -->
      <body name="link2" quat="0.707105 -0.707108 0 0">
        <inertial pos="0.04084 -0.2403 0.0324" quat="0.629322 0.758085 0.171054 -0.00125257" mass="2.242" diaginertia="0.0240043 0.0225525 0.00425325"/>
        <joint name="joint2" pos="0 0 0" axis="0 0 1" range="-2.059 2.0944"/>
        <geom type="mesh" rgba="0.3 0.3 0.38 1" mesh="link2"/>

        <!-- Link3 (joint3: elbow) -->
        <body name="link3" pos="0.0535 -0.2845 0">
          <inertial pos="0.0714 0.1268 0.0109" quat="0.83541 0.441792 -0.285476 0.159412" mass="2.019" diaginertia="0.00829354 0.00815934 0.00249212"/>
          <joint name="joint3" pos="0 0 0" axis="0 0 1" range="-3.927 0.19198"/>
          <geom type="mesh" rgba="0.35 0.35 0.4 1" mesh="link3"/>

          <!-- Link4 (joint4: wrist roll) -->
          <body name="link4" pos="0.0775 0.3425 0" quat="0.707105 -0.707108 0 0">
            <inertial pos="0.000185 0.01466 -0.02197" quat="0.999962 0.00141833 0.000640211 -0.00852665" mass="1.361" diaginertia="0.00488821 0.00418382 0.00173098"/>
            <joint name="joint4" pos="0 0 0" axis="0 0 1" range="-6.28319 6.28319"/>
            <geom type="mesh" rgba="0.3 0.3 0.38 1" mesh="link4"/>

            <!-- Link5 (joint5: wrist pitch) -->
            <body name="link5" quat="0.707105 0.707108 0 0">
              <inertial pos="0.0682 0.03342 0.00263" quat="-0.263653 0.765452 0.194903 0.5537" mass="1.345" diaginertia="0.00236723 0.0019892 0.00126157"/>
              <joint name="joint5" pos="0 0 0" axis="0 0 1" range="-1.69297 3.14159"/>
              <geom type="mesh" rgba="0.35 0.35 0.4 1" mesh="link5"/>

              <!-- Link6 (joint6: wrist yaw/flange) -->
              <body name="link6" pos="0.076 0.097 0" quat="0.707105 -0.707108 0 0">
                <inertial pos="-0.000292967 -0.00227104 0.0331897" quat="0.999508 -0.0291976 -0.0114614 -4.85474e-05" mass="0.71456" diaginertia="0.00107629 0.000915147 0.000435138"/>
                <joint name="joint6" pos="0 0 0" axis="0 0 1" range="-6.28319 6.28319"/>
                <geom type="mesh" rgba="0.25 0.25 0.35 1" mesh="link6"/>
                <geom type="mesh" rgba="0.25 0.25 0.3 1" mesh="base_link_stl"/>

                <!-- End-effector site + ego camera -->
                <site name="ee" pos="0 0 0.13" euler="0 -90 0" size="0.01" rgba="1 0 0 1"/>
                <camera name="ego" pos="0.0 0.03 0.13" xyaxes="0 1 0 0 0 1" fovy="65"/>

                <!-- ── Gripper ── -->
                <!-- drive_joint: active gripper open/close -->
                <body name="left_outer_knuckle" pos="0 0.035 0.059098">
                  <inertial pos="0 0.021559 0.015181" quat="0.47789 0.87842 0 0" mass="0.033618" diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
                  <joint name="drive_joint" pos="0 0 0" axis="1 0 0" range="0 0.85"/>
                  <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="left_outer_knuckle"/>
                  <body name="left_finger" pos="0 0.035465 0.042039">
                    <inertial pos="0 -0.016413 0.029258" quat="0.697634 0.115353 -0.115353 0.697634" mass="0.048304" diaginertia="1.88037e-05 1.7493e-05 3.56792e-06"/>
                    <joint name="left_finger_joint" pos="0 0 0" axis="-1 0 0" range="0 0.85"/>
                    <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="left_finger"/>
                  </body>
                </body>
                <body name="left_inner_knuckle" pos="0 0.02 0.074098">
                  <inertial pos="1.86601e-06 0.0220468 0.0261335" quat="0.664139 -0.242732 0.242713 0.664146" mass="0.0230126" diaginertia="8.34216e-06 6.0949e-06 2.75601e-06"/>
                  <joint name="left_inner_knuckle_joint" pos="0 0 0" axis="1 0 0" range="0 0.85"/>
                  <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="left_inner_knuckle"/>
                </body>
                <body name="right_outer_knuckle" pos="0 -0.035 0.059098">
                  <inertial pos="0 -0.021559 0.015181" quat="0.87842 0.47789 0 0" mass="0.033618" diaginertia="1.9111e-05 1.79089e-05 1.90167e-06"/>
                  <joint name="right_outer_knuckle_joint" pos="0 0 0" axis="-1 0 0" range="0 0.85"/>
                  <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="right_outer_knuckle"/>
                  <body name="right_finger" pos="0 -0.035465 0.042039">
                    <inertial pos="0 0.016413 0.029258" quat="0.697634 -0.115356 0.115356 0.697634" mass="0.048304" diaginertia="1.88038e-05 1.7493e-05 3.56779e-06"/>
                    <joint name="right_finger_joint" pos="0 0 0" axis="1 0 0" range="0 0.85"/>
                    <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="right_finger"/>
                  </body>
                </body>
                <body name="right_inner_knuckle" pos="0 -0.02 0.074098">
                  <inertial pos="1.866e-06 -0.022047 0.026133" quat="0.66415 0.242702 -0.242721 0.664144" mass="0.023013" diaginertia="8.34209e-06 6.0949e-06 2.75601e-06"/>
                  <joint name="right_inner_knuckle_joint" pos="0 0 0" axis="-1 0 0" range="0 0.85"/>
                  <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="right_inner_knuckle"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="motor1"  joint="joint1"  ctrlrange="-6.28319 6.28319" kp="300"/>
    <position name="motor2"  joint="joint2"  ctrlrange="-2.059 2.0944"   kp="300"/>
    <position name="motor3"  joint="joint3"  ctrlrange="-3.927 0.19198"  kp="300"/>
    <position name="motor4"  joint="joint4"  ctrlrange="-6.28319 6.28319" kp="300"/>
    <position name="motor5"  joint="joint5"  ctrlrange="-1.69297 3.14159" kp="300"/>
    <position name="motor6"  joint="joint6"  ctrlrange="-6.28319 6.28319" kp="300"/>
    <position name="gripper" joint="drive_joint" ctrlrange="0 0.85" kp="200"/>
  </actuator>

  <!-- Equality: mimic joints follow drive_joint -->
  <equality>
    <joint joint1="drive_joint" joint2="left_finger_joint"          polycoef="0 1 0 0 0"/>
    <joint joint1="drive_joint" joint2="left_inner_knuckle_joint"   polycoef="0 1 0 0 0"/>
    <joint joint1="drive_joint" joint2="right_outer_knuckle_joint"  polycoef="0 1 0 0 0"/>
    <joint joint1="drive_joint" joint2="right_finger_joint"         polycoef="0 1 0 0 0"/>
    <joint joint1="drive_joint" joint2="right_inner_knuckle_joint"  polycoef="0 1 0 0 0"/>
  </equality>
</mujoco>
